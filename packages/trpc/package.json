{
	"name": "@superset/trpc",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./integrations/*": {
			"types": "./src/lib/integrations/*/index.ts",
			"default": "./src/lib/integrations/*/index.ts"
		},
		"./automation-dispatch": {
			"types": "./src/router/automation/dispatch.ts",
			"default": "./src/router/automation/dispatch.ts"
		}
	},
	"scripts": {
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"test": "bun test",
		"typecheck": "tsc --noEmit --emitDeclarationOnly false"
	},
	"dependencies": {
		"@superset/auth": "workspace:*",
		"@superset/db": "workspace:*",
		"@superset/shared": "workspace:*",
		"@t3-oss/env-core": "0.13.11",
		"@trpc/server": "11.16.0",
		"@vercel/blob": "2.3.2",
		"drizzle-orm": "0.45.2",
		"superjson": "2.2.6",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@superset/typescript": "workspace:*",
		"@types/node": "24.12.0",
		"typescript": "6.0.3"
	}
}
