{
	"name": "@superset/repo",
	"version": "0.0.0",
	"repository": {
		"type": "git"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.2",
		"dotenv-cli": "11.0.0",
		"sherif": "1.11.0",
		"turbo": "2.9.14"
	},
	"description": "Superset Monorepo",
	"homepage": "https://superset.sh",
	"license": "Elastic-2.0",
	"packageManager": "bun@1.3.11",
	"private": true,
	"scripts": {
		"dev": "turbo run dev --filter=@superset/desktop --filter=//",
		"dev:all": "turbo dev",
		"dev:desktop": "turbo run dev --filter=@superset/desktop --filter=//",
		"build": "turbo build --filter=@superset/desktop",
		"test": "turbo test --concurrency=2",
		"lint": "./scripts/lint.sh",
		"check:desktop-git-env": "./scripts/check-desktop-git-env.sh",
		"lint:fix": "bunx @biomejs/biome@2.4.2 migrate --write && bunx @biomejs/biome@2.4.2 check --write --unsafe .",
		"format": "bunx @biomejs/biome@2.4.2 format --write .",
		"format:check": "bunx @biomejs/biome@2.4.2 format .",
		"typecheck": "turbo typecheck",
		"ui-add": "turbo run ui-add",
		"postinstall": "./scripts/postinstall.sh",
		"clean": "git clean -xdf node_modules",
		"clean:workspaces": "turbo clean",
		"release:desktop": "./apps/desktop/create-release.sh",
		"db:generate:desktop": "bun run --cwd packages/local-db generate"
	},
	"type": "module",
	"workspaces": [
		"packages/*",
		"apps/*",
		"tooling/*"
	],
	"overrides": {
		"axios": "1.14.0",
		"hono": "4.12.23",
		"kysely": "0.28.17"
	},
	"trustedDependencies": [
		"better-sqlite3",
		"bufferutil",
		"electron",
		"esbuild",
		"koffi",
		"node-pty",
		"sharp",
		"utf-8-validate",
		"workerd"
	],
	"dependencies": {
		"better-sqlite3": "12.10.0"
	}
}
